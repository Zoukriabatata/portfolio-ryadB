# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

CLAUDE.md
.claude
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug / logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Desktop config templates are non-secret and committed
!desktop/.env.example
!desktop/.env.production

# vercel
.vercel

# electron
.electron/
dist-electron/
electron/assets/

# typescript
*.tsbuildinfo
next-env.d.ts

# database
*.db
*.db-journal
prisma/dev.db
prisma/dev.db-journal

# temp files
nul

.vercel

backups/

# session recap files (local notes, never committed)
SESSION_*.md

# Rithmic SDK (not redistributable per Omnesys license — kept local only)
desktop/rithmic-sdk/

# Generated protobuf files (rebuilt by build.rs from rithmic-sdk/proto/).
# We commit the final mod.rs as a vendored artifact (license-safe — the
# .proto sources stay out of the repo, only the compiled Rust output
# ships) so CI without the SDK can still build. The intermediate rti.rs
# that prost emits before the rename stays ignored.
desktop/src-tauri/src/connectors/rithmic/proto/rti.rs

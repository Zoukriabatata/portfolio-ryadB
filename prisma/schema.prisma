// SENZOUKRIA Database Schema
// PostgreSQL for production (Vercel Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER MODEL ============
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?   // Hashed with bcrypt (null for OAuth users)
  name              String?
  displayName       String?
  avatar            String?

  // Email verification
  emailVerified     DateTime?
  verificationToken String?

  // Password reset
  resetToken        String?
  resetTokenExpiry  DateTime?

  // Subscription
  subscriptionTier  String    @default("FREE") // FREE | ULTRA
  subscriptionId    String?   // Stripe subscription ID
  customerId        String?   // Stripe customer ID
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?

  // One-time packs (separate from subscription)
  hasResearchPack      Boolean   @default(false) // $50 Research Library access
  researchPackBoughtAt DateTime? // Purchase timestamp

  // Security - Device & Session Management
  maxDevices        Int       @default(1) // 1 for Free, 2 for Ultra
  currentDeviceId   String?   // Active device fingerprint
  lastLoginIp       String?
  lastLoginAt       DateTime?
  failedLoginAttempts Int     @default(0)
  lockedUntil       DateTime?

  // Activity tracking
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  devices           Device[]
  payments          Payment[]
  supportTickets    SupportTicket[]
  journalEntries    JournalEntry[]
  dataFeedConfigs   DataFeedConfig[]
  promoCodeUsages   PromoCodeUsage[]
  dailyNotes        DailyNote[]
  playbookSetups    PlaybookSetup[]
  license           License?

  @@index([email])
  @@index([customerId])
}

// ============ ACCOUNT MODEL (OAuth) ============
model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String  // "oauth"
  provider          String  // "google", "github", etc.
  providerAccountId String  // Provider user ID

  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============ SESSION MODEL ============
model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String   @unique
  deviceId     String
  ipAddress    String
  userAgent    String?

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastActivity DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([deviceId])
}

// ============ DEVICE MODEL ============
model Device {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fingerprint String   // Unique device fingerprint
  name        String?  // "Chrome on Windows", etc.
  browser     String?
  os          String?

  isActive    Boolean  @default(true)
  isTrusted   Boolean  @default(false)
  lastUsed    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([userId, fingerprint])
  @@index([userId])
}

// ============ PAYMENT MODEL ============
model Payment {
  id              String  @id @default(cuid())
  userId          String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripePaymentId String? @unique
  amount          Int     // In cents
  currency        String  @default("eur")
  status          String  @default("PENDING") // PENDING | COMPLETED | FAILED | REFUNDED | CANCELLED

  tier            String  // FREE | ULTRA
  billingPeriod   String  // MONTHLY | YEARLY

  // Payment method
  paymentMethod   String  @default("STRIPE") // STRIPE | PAYPAL | REVOLUT | BINANCE | OTHER

  // Manual payment proof
  proofUrl        String? // Screenshot/receipt URL
  proofText       String? // Transaction reference or description
  adminNote       String?
  reviewedBy      String? // Admin user ID
  reviewedAt      DateTime?

  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([userId])
  @@index([stripePaymentId])
}

// ============ PROMO CODE MODELS ============
model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  discountType  String   // "PERCENTAGE" | "FIXED_AMOUNT"
  discountValue Int
  maxUses       Int
  usedCount     Int      @default(0)
  active        Boolean  @default(true)
  stripeCouponId String?
  trialDays     Int?     // Optional trial period in days (e.g., 150 for 5 months)
  validFrom     DateTime @default(now())
  validUntil    DateTime?
  createdAt     DateTime @default(now())
  usages        PromoCodeUsage[]

  @@index([code])
  @@index([active])
}

model PromoCodeUsage {
  id                String   @id @default(cuid())
  promoCodeId       String
  promoCode         PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceFingerprint String
  ipAddress         String
  userAgent         String
  emailHash         String
  paymentCompleted  Boolean @default(false)
  paymentId         String?
  usedAt            DateTime @default(now())

  @@unique([promoCodeId, userId])
  @@index([promoCodeId])
  @@index([userId])
  @@index([deviceFingerprint])
  @@index([ipAddress])
}

// ============ DATA FEED CONFIG MODEL ============
model DataFeedConfig {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider    String   // IB | DXFEED | RITHMIC | AMP
  status      String   @default("NOT_CONFIGURED") // NOT_CONFIGURED | CONFIGURED | CONNECTED | ERROR

  host        String?
  port        Int?
  username    String?
  apiKey      String?  // Should be encrypted in production

  lastConnected DateTime?
  errorMessage  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

// ============ SUPPORT TICKET MODEL ============
model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject     String
  message     String
  category    String   // BILLING | TECHNICAL | ACCOUNT | FEATURE_REQUEST | OTHER
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority    String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT

  response    String?
  respondedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============ JOURNAL MODEL ============
model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Trade details
  symbol      String   // ES, NQ, GC, etc.
  side        String   // LONG | SHORT
  entryPrice  Float
  exitPrice   Float?
  quantity    Int      @default(1)
  pnl         Float?   // Realized P&L in $

  // Metadata
  entryTime   DateTime
  exitTime    DateTime?
  timeframe   String?  // "1m", "5m", etc.
  setup       String?  // "breakout", "pullback", etc.
  tags        String?  // JSON array: ["trend", "news", "scalp"]
  notes       String?
  rating      Int?     // 1-5 self-rating
  emotions    String?  // "calm", "fomo", "revenge", etc.

  // Screenshot reference
  screenshotUrl  String?
  screenshotUrls String[]  @default([])

  // Playbook link
  playbookSetupId String?
  playbookSetup   PlaybookSetup? @relation(fields: [playbookSetupId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([symbol])
  @@index([entryTime])
}

// ============ DAILY NOTE MODEL ============
model DailyNote {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date           DateTime @db.Date
  premarketPlan  String?
  endOfDayReview String?
  lessons        String?
  mood           Int?     @default(5)
  marketConditions String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ============ PLAYBOOK SETUP MODEL ============
model PlaybookSetup {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  description    String?
  rules          String[]  @default([])
  exampleUrls    String[]  @default([])
  isActive       Boolean   @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  journalEntries JournalEntry[]

  @@unique([userId, name])
  @@index([userId])
}

// NOTE: PriceAlert model temporarily removed to align schema with live DB
// (the table was never pushed). Will be reintroduced in a dedicated PR
// with a proper add_price_alert migration. Client-side hook usePriceAlerts
// continues to fetch /api/alerts/* which now returns HTTP 503 stubs.

// ============ LICENSE STATUS ENUM ============
enum LicenseStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

// ============ LICENSE MODEL (desktop app) ============
// One license per user. Created automatically when their first Stripe
// subscription becomes 'active' (handled in /api/stripe/webhook in step 1.2).
//
// IMPORTANT: this is the IDENTITY the desktop app authenticates against.
// Independent from the web `Session` / `Device` models which track
// browser sessions on the website.
model License {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Format "OFV2-<uuid v4>" — generated server-side at License creation time.
  // The desktop app sends it back to /api/license/heartbeat for fast lookup.
  licenseKey   String        @unique

  status       LicenseStatus @default(ACTIVE)  // kill-switch for credential sharing abuse
  maxMachines  Int           @default(2)       // PC + laptop (Topstep / ATAS standard)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  machines     Machine[]

  @@index([licenseKey])
  @@index([userId])
}

// ============ MACHINE MODEL (desktop installs) ============
// Tracks desktop app installs per license. Hardware-fingerprint based.
// Different from `Device` which tracks web browser fingerprints.
//
// `lastHeartbeatAt > now() - 7 days` defines an "active" machine for
// the max-machines counting in /api/license/login.
model Machine {
  id              String   @id @default(cuid())
  licenseId       String
  license         License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  machineId       String   // hardware fingerprint from Tauri (machine-uid crate)
  os              String?  // "windows" | "macos" | "linux" — optional for tolerant edge cases
  appVersion      String?  // semver of installed app, e.g. "0.1.3"

  firstSeenAt     DateTime @default(now())
  lastHeartbeatAt DateTime @default(now())

  @@unique([licenseId, machineId])
  @@index([licenseId])
  @@index([lastHeartbeatAt])
}

// ============ WEBHOOK IDEMPOTENCE TABLE ============
// Tracks every Stripe webhook event we've processed so we can safely
// ignore replays (Stripe retries failed deliveries up to 3 days).
// Insert at the very start of the webhook handler — unique-violation
// on eventId means "already processed, skip".
//
// No relation to User: events can concern any account, we don't need
// to navigate from a user back to their events for this table's purpose.
// processedAt indexed so a future cron can purge rows > 90 days old.
model ProcessedWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique  // Stripe event.id, e.g. "evt_1Ab..."
  eventType   String              // e.g. "checkout.session.completed" — for debug / observability
  processedAt DateTime @default(now())

  @@index([processedAt])
}

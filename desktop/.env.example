# Frontend (Vite) — base URL the Tauri webview hits after license login.
#
# Build-time: inlined into the JS bundle by `tauri build`. To change it
# after a build, you must rebuild. For runtime override of the Rust
# backend's API client, use `ORDERFLOWV2_API_BASE` instead (separate var,
# read fresh on every launch).
#
# Dev: leave unset to fall back to http://localhost:3000.
# Prod: see .env.production (committed alongside this template).
# VITE_API_BASE=http://localhost:3000

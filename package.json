{
  "name": "orderflow-v2",
  "version": "0.1.0",
  "private": true,
  "main": ".electron/main.js",
  "scripts": {
    "dev": "next dev",
    "server": "node server/index.js",
    "dev:full": "concurrently \"next dev\" \"node server/index.js\"",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "analyze": "set ANALYZE=true && next build",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently --kill-others-on-fail --names next,electron \"next dev\" \"npm run electron:compile && npx wait-on http://localhost:3000 && electron .\"",
    "electron:build": "cross-env ELECTRON_BUILD=1 prisma generate && cross-env ELECTRON_BUILD=1 next build && npm run electron:compile && electron-builder",
    "electron:pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.senzoukria.desktop",
    "productName": "Senzoukria",
    "copyright": "Copyright © 2025 Senzoukria",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app"
      },
      {
        "from": ".next/static",
        "to": "app/.next/static"
      },
      {
        "from": "public",
        "to": "app/public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@dxfeed/api": "^1.6.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.38.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.2.0",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "device-detector-js": "^3.0.3",
    "express": "^4.22.1",
    "geist": "^1.7.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.575.0",
    "next": "^15.5.11",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "regl": "^2.1.1",
    "sonner": "^2.0.7",
    "stripe": "^20.3.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "javascript-obfuscator": "^5.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.5"
  }
}
